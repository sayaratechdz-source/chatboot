# ── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337

# ── Database ─────────────────────────────────────────────
DATABASE_CLIENT=mysql2
DATABASE_HOST=
DATABASE_PORT=3306
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SSL=false

# ── Strapi Keys ───────────────────────────────────────────
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
JWT_SECRET=
TRANSFER_TOKEN_SALT=

# ── Cloudinary ────────────────────────────────────────────
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR_RAILWAY_DOMAIN/api/connect/google/callback

# ── Facebook OAuth ────────────────────────────────────────
FACEBOOK_ENABLED=false
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://YOUR_RAILWAY_DOMAIN/api/connect/facebook/callback

# ── Frontend ──────────────────────────────────────────────
FRONTEND_URL=https://YOUR_FRONTEND_DOMAIN
