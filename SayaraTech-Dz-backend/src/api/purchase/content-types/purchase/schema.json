{
  "kind": "collectionType",
  "collectionName": "purchases",
  "info": {
    "singularName": "purchase",
    "pluralName": "purchases",
    "displayName": "Purchase",
    "description": "Customer purchases"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "wilaya": {
      "type": "string"
    },
    "commune": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "phone": {
      "type": "biginteger"
    },
    "quantity": {
      "type": "integer",
      "required": true
    },
    "totalPrice": {
      "type": "decimal",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "confirmed",
        "shipped",
        "delivered",
        "canceled"
      ],
      "default": "pending"
    },
    "paymentMethod": {
      "type": "enumeration",
      "enum": [
        "cash_on_delivery",
        "credit_card",
        "paypal",
        "bank_transfer"
      ],
      "default": "cash_on_delivery"
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "purchases"
    }
  }
}
