# Configuration du serveur
PORT=8000
HOST=0.0.0.0

# Clé API Anthropic (Claude) - Modèle d'IA
# Obtenez votre clé sur https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Version de l'API Anthropic
ANTHROPIC_VERSION=

# Modèle Claude à utiliser
CLAUDE_MODEL=

# Base de données (Strapi CMS)
# Renseigner l'URL complète de votre Strapi (local ou distant) et le Token d'accès
STRAPI_API_URL=http://localhost:1337
STRAPI_API_TOKEN=your_strapi_api_token_here

# Environnement (development, production)
ENVIRONMENT=development
